# Multi-Cloud Scheduler — Credentials & Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this to .env and fill in your values.
# Load with: export $(grep -v '^#' .env | xargs)
# Or use python-dotenv in your app.
# NEVER commit this file with real values.

# ══════════════════════════════════════════════════════════════
# GCP
# ══════════════════════════════════════════════════════════════

# Your GCP project ID (from GCP Console → Project Info)
GCP_PROJECT_ID=tensile-method-459009-k2

# Region + zone for VM launch
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# Path to your service account JSON key
# Create via: gcloud iam service-accounts keys create key.json --iam-account=SA_EMAIL
# Required roles: Compute Admin, Storage Object Admin
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-sa-key.json

# Service account email (for VM identity)
# Create via: gcloud iam service-accounts create ml-scheduler
GCP_SERVICE_ACCOUNT_EMAIL=ml-scheduler@YOUR_PROJECT.iam.gserviceaccount.com

# GCS bucket for checkpoints
# Create via: gsutil mb gs://your-checkpoint-bucket
CHECKPOINT_GCS_BUCKET=your-checkpoint-bucket

# ══════════════════════════════════════════════════════════════
# AWS
# ══════════════════════════════════════════════════════════════

# IAM user credentials (create in IAM Console → Users → Security Credentials)
# Required policies: AmazonEC2FullAccess, AmazonS3FullAccess
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Region for EC2 Spot
AWS_REGION=us-east-1

# Deep Learning AMI (Ubuntu 22.04 + PyTorch)
# Find latest: aws ec2 describe-images --owners amazon \
#   --filters "Name=name,Values=Deep Learning AMI GPU PyTorch*"
AWS_AMI_ID=ami-0abcdef1234567890

# VPC subnet (must be in AWS_REGION)
# Find via: aws ec2 describe-subnets
AWS_SUBNET_ID=subnet-0123456789abcdef0

# Security group (allow SSH:22, training ports)
# Create via: aws ec2 create-security-group --group-name ml-sg --description "ML training"
AWS_SECURITY_GROUP_ID=sg-0123456789abcdef0

# EC2 instance profile ARN (for S3 access from the VM)
# Create via IAM Console → Roles → Create Role → EC2 → AmazonS3FullAccess
AWS_IAM_INSTANCE_PROFILE=arn:aws:iam::123456789012:instance-profile/ml-training-profile

# Optional: EC2 key pair name for SSH access
# Create via: aws ec2 create-key-pair --key-name ml-key
AWS_KEY_PAIR_NAME=ml-key

# S3 bucket for checkpoints
# Create via: aws s3 mb s3://your-checkpoint-bucket
CHECKPOINT_S3_BUCKET=your-checkpoint-bucket

# ══════════════════════════════════════════════════════════════
# AZURE
# ══════════════════════════════════════════════════════════════

# Subscription ID (Azure Portal → Subscriptions)
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Azure AD App Registration (for service principal auth)
# Create via: az ad sp create-for-rbac --name ml-scheduler --role Contributor
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-value

# Resource group (pre-create or let launcher create it)
# Create via: az group create --name ml-scheduler-rg --location eastus
AZURE_RESOURCE_GROUP=ml-scheduler-rg

# Location for Azure resources
AZURE_LOCATION=eastus

# VNet + Subnet (pre-created)
# Create via:
#   az network vnet create --name ml-vnet --resource-group ml-scheduler-rg --address-prefix 10.0.0.0/16
#   az network vnet subnet create --name ml-subnet --vnet-name ml-vnet --resource-group ml-scheduler-rg --address-prefix 10.0.1.0/24
AZURE_VNET_NAME=ml-vnet
AZURE_SUBNET_NAME=ml-subnet

# NSG (Network Security Group)
# Create via: az network nsg create --name ml-nsg --resource-group ml-scheduler-rg
AZURE_NSG_NAME=ml-nsg

# VM admin credentials (password min 12 chars, 3 of: upper/lower/digit/special)
AZURE_VM_USERNAME=azureuser
AZURE_VM_PASSWORD=YourStr0ng!Pass

# ══════════════════════════════════════════════════════════════
# SCHEDULER TUNING
# ══════════════════════════════════════════════════════════════

# Pareto scoring weights (must sum to 1.0)
# COST:  prefer cheaper instances
# RISK:  prefer lower preemption probability
# TIME:  prefer faster completion
SELECTOR_W_COST=0.40
SELECTOR_W_RISK=0.35
SELECTOR_W_TIME=0.25

# Path to job state file
JOB_STATE_PATH=job_state.json

# ══════════════════════════════════════════════════════════════
# HOW TO GET EACH CREDENTIAL
# ══════════════════════════════════════════════════════════════
#
# GCP Service Account Key:
#   1. GCP Console → IAM & Admin → Service Accounts
#   2. Create account: ml-scheduler@PROJECT.iam.gserviceaccount.com
#   3. Grant roles: Compute Admin, Storage Object Admin, Service Account User
#   4. Keys → Add Key → JSON → download to gcp-sa-key.json
#
# AWS IAM User:
#   1. AWS Console → IAM → Users → Create User
#   2. Attach policies: AmazonEC2FullAccess, AmazonS3FullAccess
#   3. Security Credentials → Create Access Key → Application running on AWS
#   4. Copy Access Key ID + Secret
#
# AWS Instance Profile (for EC2 → S3 access):
#   1. IAM → Roles → Create Role → AWS Service → EC2
#   2. Attach: AmazonS3FullAccess
#   3. Name: ml-training-profile
#   4. Go to role → Instance Profile ARN (shown at top)
#
# Azure Service Principal:
#   Run: az ad sp create-for-rbac \
#          --name ml-scheduler \
#          --role Contributor \
#          --scopes /subscriptions/YOUR_SUBSCRIPTION_ID
#   Output gives: appId (CLIENT_ID), password (CLIENT_SECRET), tenant (TENANT_ID)
#
# ══════════════════════════════════════════════════════════════
# MINIMUM REQUIRED TO RUN (one cloud only)
# ══════════════════════════════════════════════════════════════
#
# GCP only:   GCP_PROJECT_ID, GOOGLE_APPLICATION_CREDENTIALS,
#             GCP_SERVICE_ACCOUNT_EMAIL, CHECKPOINT_GCS_BUCKET
#
# AWS only:   AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY,
#             AWS_AMI_ID, AWS_SUBNET_ID, AWS_SECURITY_GROUP_ID,
#             AWS_IAM_INSTANCE_PROFILE, CHECKPOINT_S3_BUCKET
#
# Azure only: AZURE_SUBSCRIPTION_ID, AZURE_TENANT_ID,
#             AZURE_CLIENT_ID, AZURE_CLIENT_SECRET,
#             AZURE_RESOURCE_GROUP, AZURE_VM_PASSWORD
